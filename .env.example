# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1

# Amazon Bedrock Configuration
BEDROCK_REGION=us-east-1
NOVA_LITE_MODEL_ID=amazon.nova-lite-v1:0
NOVA_PRO_MODEL_ID=amazon.nova-pro-v1:0

# AWS S3 Configuration
S3_BUCKET_NAME=novarescue-uploads
S3_REGION=us-east-1

# Application Configuration
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# CORS — set to "*" for production on Render so the Vercel frontend can reach
# the backend.  For local dev you can restrict to specific origins.
CORS_ORIGINS=*

# Simulation Mode (set to true for demo without AWS credentials)
SIMULATION_MODE=true

# ---------------------------------------------------------------------------
# Frontend (Vercel) environment variable
# ---------------------------------------------------------------------------
# Set this in your Vercel project → Settings → Environment Variables so the
# React app knows where the Render backend lives.
# Example: https://novarescue-backend.onrender.com
REACT_APP_API_URL=https://your-render-backend-url.onrender.com
